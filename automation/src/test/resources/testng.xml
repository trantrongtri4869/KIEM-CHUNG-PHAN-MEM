<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="GearVault Automation Suite" verbose="1" parallel="none">

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.gearvault.tests.LoginTest"/>
            <class name="com.gearvault.tests.RegisterTest"/>
            <class name="com.gearvault.tests.ProductTest"/>
            <class name="com.gearvault.tests.CartTest"/>
            <class name="com.gearvault.tests.CheckoutTest"/>        <!-- thêm -->
            <class name="com.gearvault.tests.LogoutAndNavTest"/>    <!-- thêm -->
            <class name="com.gearvault.tests.ProductFilterTest"/>   <!-- thêm -->
        </classes>
    </test>

    <test name="Authentication Tests">
        <classes>
            <class name="com.gearvault.tests.LoginTest"/>
            <class name="com.gearvault.tests.RegisterTest"/>
        </classes>
    </test>

    <test name="Product Tests">
        <classes>
            <class name="com.gearvault.tests.ProductTest"/>
            <class name="com.gearvault.tests.ProductFilterTest"/>   <!-- thêm -->
        </classes>
    </test>

    <test name="Cart and Checkout Tests">
        <classes>
            <class name="com.gearvault.tests.CartTest"/>
            <class name="com.gearvault.tests.CheckoutTest"/>        <!-- thêm -->
        </classes>
    </test>

    <test name="Navigation Tests">                                  <!-- block mới -->
        <classes>
            <class name="com.gearvault.tests.LogoutAndNavTest"/>
        </classes>
    </test>

    <listeners>
        <listener class-name="org.testng.reporters.SuiteHTMLReporter"/>
    </listeners>

</suite>